# ============================================================
#  YARÃ API — Variáveis de Ambiente
#  SPRINT 01: mover credenciais para cá e NUNCA commitar este
#  arquivo real no Git (apenas o .env.example).
#  Adicione ao .gitignore: .env
# ============================================================

# Banco de dados
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=yara_db
DB_PORT=3307

# JWT — MUDE ISTO EM PRODUÇÃO para uma string aleatória longa
JWT_SECRET=mude_isto_para_um_segredo_seguro_em_producao

# Porta da API
PORT=8080

# CORS: origens permitidas separadas por vírgula
# Em produção: https://www.yaraportal.com.br
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500
